PORT=5001
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<db-name>
JWT_SECRET=change-this-in-production
JWT_EXPIRE=7d
FRONTEND_URL=http://localhost:3001
EASYPG_DOCUMENT_BASE_URL=http://localhost:5001

# SMTP settings for direct email replies from Admin panel
# Recommended for Gmail:
# SMTP_SERVICE=gmail
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM=EasyPG Admin <your-email@gmail.com>

# Generic SMTP (if not using SMTP_SERVICE):
# SMTP_HOST=smtp.your-provider.com
# SMTP_PORT=587
# SMTP_SECURE=false

SMTP_SERVICE=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
